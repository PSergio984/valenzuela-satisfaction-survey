APP_NAME="Survey System"
APP_ENV=production
APP_KEY=                          # php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://your-app.onrender.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ─── Database ─────────────────────────────────────────────────────────────────
# On Render: set DATABASE_URL to the Internal Database URL from your Render
# PostgreSQL service. Laravel will parse it automatically via DATABASE_URL.
# The individual DB_* vars serve as a local-dev fallback.
#
# Render provides:  postgresql://user:password@host:5432/dbname
#
DB_CONNECTION=pgsql
DATABASE_URL=                     # paste Render's Internal Database URL here
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=survey_system
DB_USERNAME=postgres
DB_PASSWORD=
DB_SSLMODE=require                # Render PostgreSQL requires SSL

# ─── Session / Cache / Queue ─────────────────────────────────────────────────
# Use 'database' driver – no extra services needed on Render free tier.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# ─── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── AWS / S3 (optional) ─────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
